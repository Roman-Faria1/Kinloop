    "inngest:dev": "npx inngest-cli dev -u http://localhost:3000/api/inngest"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "class-variance-authority": "^0.7.1",
